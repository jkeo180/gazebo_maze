<?xml version="1.0" ?>
<sdf version="1.8">

<model name="my_robot">

  <pose>-2.5 -2.8 0.1 0 0 -1.5708</pose>

  <!-- ================= CHASSIS ================= -->
  <link name="chassis">
    <inertial>
  <pose>0 0 0 0 0 0</pose>
  <mass>5.0</mass>
  <inertia>
    <ixx>1.56</ixx>
    <ixy>0.0</ixy>
    <ixz>0.0</ixz>
    <iyy>5.31</iyy>
    <iyz>0.0</iyz>
    <izz>5.62</izz>
    </inertia>
</inertial>

    <collision name="collision">
      <geometry>
        <box><size>2.0 1.0 0.5</size></box>
      </geometry>
    </collision>

    <visual name="visual">
      <geometry>
        <box><size>2.0 1.0 0.5</size></box>
      </geometry>
      <material>
        <ambient>1.0 0 1 1</ambient>
        <diffuse>1.0 0 1 1</diffuse>
      </material>
    </visual>
  </link>

  <!-- ================= IMU ================= -->
  <link name="imu_link">
    <pose>0 0 0.1 0 0 0</pose>
    <inertial>
      <mass>0.1</mass>
    </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent>chassis</parent>
    <child>imu_link</child>
  </joint>

   <!-- ================= LIDAR LINK ================= -->
  <link name="lidar_link">
    <pose>0 0 0.15 0 0 0</pose>
    <inertial>
      <mass>0.1</mass>
      <inertia>
  <ixx>0.1</ixx>
  <ixy>0.0</ixy>
  <ixz>0.0</ixz>
      </inertia>
    </inertial>
    <collision name="lidar_collision">
      <geometry>
        <cylinder><radius>0.05</radius><length>0.05</length></cylinder>
      </geometry>
    </collision>
    <visual name="lidar_visual">
      <geometry>
        <cylinder><radius>0.05</radius><length>0.05</length></cylinder>
      </geometry>
    </visual>
  </link>

  <!-- ================= LIDAR JOINT ================= -->
  <joint name="lidar_joint" type="fixed">
    <parent>chassis</parent>
    <child>lidar_link</child>
    <pose>0 0 0 0 0 0</pose>
  </joint>
  <!-- ================= LEFT WHEEL JOINT ================= -->
  <joint name="left_wheel_joint" type="revolute">
    <parent>chassis</parent>
    <child>left_back_wheel</child>
    <dynamics>
  <damping>0.2</damping>
</dynamics>
    <axis>
      <xyz>0 1 0</xyz>
      <limit><lower>-1.79769e+308</lower><upper>1.79769e+308</upper></limit>
    </axis>
  </joint>

  <!-- ================= RIGHT WHEEL JOINT ================= -->
  <joint name="right_wheel_joint" type="revolute">
    <parent>chassis</parent>
    <child>right_back_wheel</child>
    <dynamics>
  <damping>0.2</damping>
</dynamics>
    <axis>
      <xyz>0 1 0</xyz>
      <limit><lower>-1.79769e+308</lower><upper>1.79769e+308</upper></limit>
    </axis>
  </joint>

  <!-- ================= DRIVE PLUGIN ================= -->
  <plugin filename="gz-sim-diff-drive-system"
          name="gz::sim::systems::DiffDrive">
    <left_wheel_joint>left_wheel_joint</left_wheel_joint>
    <right_wheel_joint>right_wheel_joint</right_wheel_joint>
    <wheel_separation>0.26</wheel_separation>
    <wheel_radius>0.1</wheel_radius>
    <odom_publish_frequency>10</odom_publish_frequency>
    <topic>/cmd_vel</topic>
  </plugin>

</model>
</sdf>
