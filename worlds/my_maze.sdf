<?xml version="1.0" ?>
<sdf version="1.8">
  <world name="maze_world">
    <!-- ================= LIGHTING ================= -->
    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- ================= GROUND PLANE ================= -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane><normal>0 0 1</normal></plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane><normal>0 0 1</normal><size>100 100</size></plane>
          </geometry>
        </visual>
      </link>
    </model>

    <!-- ================= MAZE WALLS ================= -->
    <model name="wall_1">
      <static>true</static>
      <pose>-3 0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.2 4.0 1.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.2 4.0 1.0</size></box></geometry></visual>
      </link>
    </model>

    <model name="wall_2a">
      <static>true</static>
      <pose>0 2.2 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>3.0 0.2 1.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>3.0 0.2 1.0</size></box></geometry></visual>
      </link>
    </model>

    <model name="wall_2b">
      <static>true</static>
      <pose>2.5 2 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>1.0 0.2 1.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>1.0 0.2 1.0</size></box></geometry></visual>
      </link>
    </model>

    <model name="wall_3">
      <static>true</static>
      <pose>0 0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>4.0 0.2 1.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>4.0 0.2 1.0</size></box></geometry></visual>
      </link>
    </model>

    <model name="wall_4">
      <static>true</static>
      <pose>3 0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.2 4.0 1.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.2 4.0 1.0</size></box></geometry></visual>
      </link>
    </model>

    <model name="wall_5">
      <static>true</static>
      <pose>1 -1 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>2.0 0.2 1.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>2.0 0.2 1.0</size></box></geometry></visual>
      </link>
    </model>

    <model name="wall_6">
      <static>true</static>
      <pose>1 -2 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>5.0 0.2 1.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>5.0 0.2 1.0</size></box></geometry></visual>
      </link>
    </model>

    <model name="wall_7">
      <static>true</static>
      <pose>2 1.4 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.2 1.5 1.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.2 1.5 1.0</size></box></geometry></visual>
      </link>
    </model>

    <model name="wall_8">
      <static>true</static>
      <pose>-1.5 1.2 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>3.0 0.2 1.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>3.0 0.2 1.0</size></box></geometry></visual>
      </link>
    </model>

    <model name="wall_9">
      <static>true</static>
      <pose>-1.5 -1 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>1.5 0.2 1.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>1.5 0.2 1.0</size></box></geometry></visual>
      </link>
    </model>

  <!-- ================= MY ROBOT ================= -->
<model name="my_robot">
  <static>false</static>
  <!-- Spawn height = wheel radius, since chassis link origin is now at axle height -->
  <pose>-2.5 -2 0.1 0 0 1.5707</pose>

  <!-- CHASSIS - link origin is at wheel-axle height, box visual/collision shifted up -->
  <link name="chassis">
    <pose>0 0 0 0 0 0</pose>
    <inertial>
      <pose>0.1 0 0.075 0 0 0</pose>
      <mass>5.0</mass>
      <inertia>
        <ixx>0.026042</ixx><ixy>0.0</ixy><ixz>0.0</ixz>
        <iyy>0.076042</iyy><iyz>0.0</iyz>
        <izz>0.083333</izz>
      </inertia>
    </inertial>
    <collision name="collision">
      <pose>0.1 0 0.075 0 0 0</pose>
      <geometry>
        <box><size>0.4 0.2 0.15</size></box>
      </geometry>
    </collision>
    <visual name="visual">
      <pose>0.1 0 0.075 0 0 0</pose>
      <geometry>
        <box><size>0.4 0.2 0.15</size></box>
      </geometry>
      <material>
        <ambient>0 0 1 1</ambient>
        <diffuse>0 0 1 1</diffuse>
      </material>
    </visual>
  </link>

  <!-- LIDAR LINK - sits on top of chassis -->
  <link name="lidar_link">
    <pose>0.1 0 0.2 0 0 0</pose>
    <inertial>
      <mass>0.1</mass>
      <inertia>
        <ixx>0.000083</ixx><ixy>0.0</ixy><ixz>0.0</ixz>
        <iyy>0.000083</iyy><iyz>0.0</iyz>
        <izz>0.000125</izz>
      </inertia>
    </inertial>
    <collision name="collision">
      <geometry>
        <cylinder><radius>0.05</radius><length>0.05</length></cylinder>
      </geometry>
    </collision>
    <visual name="visual">
      <geometry>
        <cylinder><radius>0.05</radius><length>0.05</length></cylinder>
      </geometry>
      <material>
        <ambient>0.2 0.2 0.2 1</ambient>
        <diffuse>0.2 0.2 0.2 1</diffuse>
      </material>
    </visual>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent>chassis</parent>
    <child>lidar_link</child>
  </joint>

  <!-- LEFT WHEEL - centered at axle height (z=0 relative to model origin) -->
  <link name="left_back_wheel">
    <pose>0 0.15 0 1.5707 0 0</pose>
    <inertial>
      <mass>0.5</mass>
      <inertia>
        <ixx>0.001317</ixx><ixy>0.0</ixy><ixz>0.0</ixz>
        <iyy>0.001317</iyy><iyz>0.0</iyz>
        <izz>0.002500</izz>
      </inertia>
    </inertial>
    <collision name="collision">
      <geometry>
        <cylinder><radius>0.1</radius><length>0.04</length></cylinder>
      </geometry>
      <surface>
        <friction>
          <ode><mu>1.0</mu><mu2>0.5</mu2></ode>
        </friction>
      </surface>
    </collision>
    <visual name="visual">
      <geometry>
        <cylinder><radius>0.1</radius><length>0.04</length></cylinder>
      </geometry>
      <material>
        <ambient>0 0 0 1</ambient>
        <diffuse>0 0 0 1</diffuse>
      </material>
    </visual>
  </link>

  <joint name="left_wheel_joint" type="revolute">
    <parent>chassis</parent>
    <child>left_back_wheel</child>
    <axis>
      <xyz>0 1 0</xyz>
    </axis>
  </joint>

  <!-- RIGHT WHEEL -->
  <link name="right_back_wheel">
    <pose>0 -0.15 0 1.5707 0 0</pose>
    <inertial>
      <mass>0.5</mass>
      <inertia>
        <ixx>0.001317</ixx><ixy>0.0</ixy><ixz>0.0</ixz>
        <iyy>0.001317</iyy><iyz>0.0</iyz>
        <izz>0.002500</izz>
      </inertia>
    </inertial>
    <collision name="collision">
      <geometry>
        <cylinder><radius>0.1</radius><length>0.04</length></cylinder>
      </geometry>
      <surface>
        <friction>
          <ode><mu>1.0</mu><mu2>0.5</mu2></ode>
        </friction>
      </surface>
    </collision>
    <visual name="visual">
      <geometry>
        <cylinder><radius>0.1</radius><length>0.04</length></cylinder>
      </geometry>
      <material>
        <ambient>0 0 0 1</ambient>
        <diffuse>0 0 0 1</diffuse>
      </material>
    </visual>
  </link>

  <joint name="right_wheel_joint" type="revolute">
    <parent>chassis</parent>
    <child>right_back_wheel</child>
    <axis>
      <xyz>0 1 0</xyz>
    </axis>
  </joint>

  <!-- FRONT CASTER - bottom of sphere matches wheel-radius height -->
  <link name="front_wheel">
    <pose>0.3 0 -0.05 0 0 0</pose>
    <inertial>
      <mass>0.2</mass>
      <inertia>
        <ixx>0.000200</ixx><ixy>0.0</ixy><ixz>0.0</ixz>
        <iyy>0.000200</iyy><iyz>0.0</iyz>
        <izz>0.000200</izz>
      </inertia>
    </inertial>
    <collision name="collision">
      <geometry>
        <sphere><radius>0.05</radius></sphere>
      </geometry>
      <surface>
        <friction>
          <ode><mu>0.0</mu><mu2>0.0</mu2></ode>
        </friction>
      </surface>
    </collision>
    <visual name="visual">
      <geometry>
        <sphere><radius>0.05</radius></sphere>
      </geometry>
      <material>
        <ambient>0.5 0.5 0.5 1</ambient>
        <diffuse>0.5 0.5 0.5 1</diffuse>
      </material>
    </visual>
  </link>

  <joint name="front_wheel_joint" type="ball">
    <parent>chassis</parent>
    <child>front_wheel</child>
  </joint>

  <!-- DIFF DRIVE PLUGIN -->
  <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
    <left_joint>left_wheel_joint</left_joint>
    <right_joint>right_wheel_joint</right_joint>
    <wheel_separation>0.30</wheel_separation>
    <wheel_radius>0.1</wheel_radius>
    <odom_publish_frequency>10</odom_publish_frequency>
    <max_linear_velocity>0.5</max_linear_velocity>
    <min_linear_velocity>-0.5</min_linear_velocity>
    <max_angular_velocity>1.0</max_angular_velocity>
    <min_angular_velocity>-1.0</min_angular_velocity>
    <topic>/cmd_vel</topic>
  </plugin>

</model>

  </world>
</sdf>